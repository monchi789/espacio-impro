---
interface Props {
  title?: string
}
const { title = 'Dashboard — Impronakuy 2026' } = Astro.props
---
<!DOCTYPE html>
<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <link rel="preload" href="/fonts/Manrope-SemiBold.woff2" as="font" type="font/woff2" crossorigin />
    <link rel="preload" href="/fonts/Inter_18pt-Medium.woff2" as="font" type="font/woff2" crossorigin />
    <link rel="preload" href="/fonts/Inter_18pt-Regular.woff2" as="font" type="font/woff2" crossorigin />
  </head>
  <body class="dashboard-page">
    <nav class="db-sidebar">
      <div class="db-logo">IMPRONAKUY<br /><span>2026</span></div>
      <div class="db-nav-links">
        <a href="/dashboard/fechas">Fechas</a>
      </div>
      <button id="db-logout-btn" class="db-logout">Cerrar sesión</button>
    </nav>
    <main class="db-main">
      <slot />
    </main>

    <script>
      const btn = document.getElementById('db-logout-btn')
      btn?.addEventListener('click', () => {
        window.localStorage.removeItem('impronakuy_admin_token')
        window.location.href = '/dashboard/login'
      })
    </script>

    <style is:global>
      @font-face {
        font-family: 'Manrope';
        font-style: normal;
        font-weight: 600;
        font-display: swap;
        src: url('/fonts/Manrope-SemiBold.woff2') format('woff2');
      }
      @font-face {
        font-family: 'Inter';
        font-style: normal;
        font-weight: 400;
        font-display: swap;
        src: url('/fonts/Inter_18pt-Regular.woff2') format('woff2');
      }
      @font-face {
        font-family: 'Inter';
        font-style: normal;
        font-weight: 500;
        font-display: swap;
        src: url('/fonts/Inter_18pt-Medium.woff2') format('woff2');
      }

      body.dashboard-page {
        --db-bg: #0f172a;
        --db-surface: #1e293b;
        --db-surface-2: #273449;
        --db-border: #334155;
        --db-text: #e2e8f0;
        --db-muted: #94a3b8;
        --db-accent: #818cf8;
        --db-accent-hover: #6366f1;
        --db-success: #4ade80;
        --db-warning: #fbbf24;
        --db-danger: #f87171;

        margin: 0;
        padding: 0;
        min-height: 100vh;
        background: var(--db-bg);
        color: var(--db-text);
        font-family: 'Inter', system-ui, sans-serif;
        font-size: 14px;
        display: grid;
        grid-template-columns: 220px 1fr;
      }

      body.dashboard-page * {
        box-sizing: border-box;
      }

      body.dashboard-page h1,
      body.dashboard-page h2,
      body.dashboard-page h3 {
        font-family: 'Manrope', system-ui, sans-serif;
        font-weight: 600;
        margin: 0 0 1rem;
      }

      body.dashboard-page a {
        color: inherit;
        text-decoration: none;
      }

      body.dashboard-page button {
        font-family: inherit;
        font-size: inherit;
        cursor: pointer;
      }

      body.dashboard-page .db-sidebar {
        position: sticky;
        top: 0;
        height: 100vh;
        background: var(--db-surface);
        border-right: 1px solid var(--db-border);
        padding: 1.5rem 1rem;
        display: flex;
        flex-direction: column;
        gap: 1rem;
      }

      body.dashboard-page .db-logo {
        font-family: 'Manrope', sans-serif;
        font-weight: 600;
        font-size: 1.05rem;
        letter-spacing: 0.04em;
        line-height: 1.1;
        margin-bottom: 1.5rem;
      }
      body.dashboard-page .db-logo span {
        color: var(--db-accent);
      }

      body.dashboard-page .db-nav-links {
        display: flex;
        flex-direction: column;
        gap: 0.25rem;
        flex: 1;
      }

      body.dashboard-page .db-nav-links a {
        padding: 0.6rem 0.8rem;
        border-radius: 8px;
        color: var(--db-muted);
        font-weight: 500;
        transition: background 0.15s, color 0.15s;
      }
      body.dashboard-page .db-nav-links a:hover {
        background: var(--db-surface-2);
        color: var(--db-text);
      }

      body.dashboard-page .db-logout {
        background: transparent;
        border: 1px solid var(--db-border);
        color: var(--db-muted);
        padding: 0.6rem 0.8rem;
        border-radius: 8px;
        transition: all 0.15s;
      }
      body.dashboard-page .db-logout:hover {
        border-color: var(--db-danger);
        color: var(--db-danger);
      }

      body.dashboard-page .db-main {
        padding: 2rem;
        overflow-x: auto;
      }

      body.dashboard-page input,
      body.dashboard-page select {
        background: var(--db-bg);
        border: 1px solid var(--db-border);
        color: var(--db-text);
        padding: 0.7rem 0.9rem;
        border-radius: 8px;
        font-family: inherit;
        font-size: 16px;
        width: 100%;
      }
      body.dashboard-page input:focus,
      body.dashboard-page select:focus {
        outline: none;
        border-color: var(--db-accent);
      }

      body.dashboard-page button {
        min-height: 44px;
      }

      @media (max-width: 768px) {
        body.dashboard-page {
          grid-template-columns: 1fr;
          font-size: 15px;
        }
        body.dashboard-page .db-sidebar {
          position: sticky;
          top: 0;
          z-index: 50;
          height: auto;
          flex-direction: row;
          align-items: center;
          gap: 0.5rem;
          padding: 0.6rem 0.9rem;
          border-right: 0;
          border-bottom: 1px solid var(--db-border);
          backdrop-filter: blur(8px);
        }
        body.dashboard-page .db-logo {
          font-size: 0.95rem;
          margin-bottom: 0;
          flex: 0 0 auto;
        }
        body.dashboard-page .db-logo br {
          display: none;
        }
        body.dashboard-page .db-logo span {
          margin-left: 0.3rem;
        }
        body.dashboard-page .db-nav-links {
          flex-direction: row;
          gap: 0.25rem;
          overflow-x: auto;
        }
        body.dashboard-page .db-nav-links a {
          padding: 0.55rem 0.75rem;
          white-space: nowrap;
          font-size: 0.9rem;
        }
        body.dashboard-page .db-logout {
          padding: 0.55rem 0.75rem;
          font-size: 0.85rem;
          flex: 0 0 auto;
        }
        body.dashboard-page .db-main {
          padding: 1rem 0.85rem 5rem;
        }
        body.dashboard-page h1 {
          font-size: 1.4rem;
        }
        body.dashboard-page h2 {
          font-size: 1.15rem;
        }
        body.dashboard-page h3 {
          font-size: 1rem;
        }
      }
    </style>
  </body>
</html>
