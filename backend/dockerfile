# Build stage
FROM python:3.13-slim as builder

WORKDIR /app

# Instalar Poetry
RUN pip install --no-cache-dir poetry

# Configuración vital para que cree la carpeta .venv en el lugar correcto
ENV POETRY_VIRTUALENVS_IN_PROJECT=true \
    POETRY_VIRTUALENVS_CREATE=true

# Copiar archivos de configuración
COPY pyproject.toml poetry.lock* ./

# Instalar dependencias
# (Aseguramos regenerar el lock y no instalar el proyecto raíz aún)
RUN poetry lock && \
    poetry install --only main --no-root --no-interaction --no-ansi

# Runtime stage
FROM python:3.13-slim

WORKDIR /app

# Variables de entorno para usar el entorno virtual creado arriba
ENV PYTHONUNBUFFERED=1 \
    PYTHONDONTWRITEBYTECODE=1 \
    PATH="/app/.venv/bin:$PATH" \
    VIRTUAL_ENV="/app/.venv"

# Copiar el entorno virtual desde la etapa builder
COPY --from=builder /app/.venv /app/.venv

# Copiar el código fuente
COPY src ./src

# Crear directorio de datos
RUN mkdir -p /app/data

# Puerto
EXPOSE 8000

# Health check (usando librería estándar de Python)
HEALTHCHECK --interval=30s --timeout=10s --start-period=40s --retries=3 \
    CMD python -c "import urllib.request; urllib.request.urlopen('http://localhost:8000')" || exit 1

# Arrancar la aplicación
CMD ["python", "-m", "uvicorn", "src.main:app", "--host", "0.0.0.0", "--port", "8000"]